generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SALES
}

enum LeadState {
  LEAD
  CUSTOMER
  DORMANT
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  FOLLOW_UP
}

enum ActivityStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum PipelineStageKind {
  OPEN
  WON
  LOST
  DORMANT
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum OrderStatus {
  DRAFT
  BOOKED
  IN_PRODUCTION
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum ProductionStageStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
  SKIPPED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SALES)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedLeadCustomers       LeadCustomer[]         @relation("LeadOwner")
  createdLeadCustomers     LeadCustomer[]         @relation("LeadCreatedBy")
  updatedLeadCustomers     LeadCustomer[]         @relation("LeadUpdatedBy")
  ownedActivities          Activity[]             @relation("ActivityOwner")
  createdActivities        Activity[]             @relation("ActivityCreatedBy")
  completedActivities      Activity[]             @relation("ActivityCompletedBy")
  ownershipChangesFrom     LeadOwnershipHistory[] @relation("LeadOwnershipFrom")
  ownershipChangesTo       LeadOwnershipHistory[] @relation("LeadOwnershipTo")
  ownershipChangesChanged  LeadOwnershipHistory[] @relation("LeadOwnershipChangedBy")
  ownedOpportunities       Opportunity[]          @relation("OpportunityOwner")
  createdOpportunities     Opportunity[]          @relation("OpportunityCreatedBy")
  updatedOpportunities     Opportunity[]          @relation("OpportunityUpdatedBy")
  opportunitySplits        OpportunityOwnerSplit[]
  salesTargets             SalesTarget[]          @relation("SalesTargetOwner")
  salesTargetsCreated      SalesTarget[]          @relation("SalesTargetCreatedBy")
  createdProductServices   ProductService[]       @relation("ProductServiceCreatedBy")
  updatedProductServices   ProductService[]       @relation("ProductServiceUpdatedBy")
  createdProposals         Proposal[]             @relation("ProposalCreatedBy")
  updatedProposals         Proposal[]             @relation("ProposalUpdatedBy")
  uploadedProposalPdfs     ProposalPdfAttachment[] @relation("ProposalPdfUploadedBy")
  ownedOrders              Order[]                @relation("OrderOwner")
  createdOrders            Order[]                @relation("OrderCreatedBy")
  updatedOrders            Order[]                @relation("OrderUpdatedBy")
  orderSplitSnapshots      OrderOwnerSplitSnapshot[]
  assignedProductionWorkItems ProductionWorkItem[] @relation("ProductionWorkItemAssignedTo")
  createdProductionWorkItems  ProductionWorkItem[] @relation("ProductionWorkItemCreatedBy")
  updatedProductionWorkItems  ProductionWorkItem[] @relation("ProductionWorkItemUpdatedBy")
  assignedProductionStages    ProductionStageInstance[] @relation("ProductionStageAssignedTo")
  completedProductionStages   ProductionStageInstance[] @relation("ProductionStageCompletedBy")
  createdProductionNotes      ProductionNote[]     @relation("ProductionNoteCreatedBy")
}

model LeadCustomer {
  id          String    @id @default(cuid())
  name        String
  state       LeadState @default(LEAD)
  industry    String?
  source      String?
  ownerId     String
  notes       String?
  createdById String
  updatedById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner            User                   @relation("LeadOwner", fields: [ownerId], references: [id])
  createdBy        User                   @relation("LeadCreatedBy", fields: [createdById], references: [id])
  updatedBy        User                   @relation("LeadUpdatedBy", fields: [updatedById], references: [id])
  branches         Branch[]
  contacts         Contact[]
  activities       Activity[]
  ownershipHistory LeadOwnershipHistory[]
  opportunities    Opportunity[]
  orders           Order[]

  @@index([ownerId])
  @@index([state])
  @@index([name])
  @@index([createdAt])
}

model Branch {
  id             String   @id @default(cuid())
  leadCustomerId String
  name           String
  addressLine1   String?
  addressLine2   String?
  city           String?
  region         String?
  postalCode     String?
  country        String   @default("India")
  gstin          String?
  locationHint   String?
  salesContext   String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leadCustomer LeadCustomer @relation(fields: [leadCustomerId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  activities   Activity[]
  opportunities Opportunity[]
  orders       Order[]

  @@index([leadCustomerId])
  @@index([city])
}

model Contact {
  id             String   @id @default(cuid())
  leadCustomerId String
  branchId       String?
  name           String
  designation    String?
  email          String?
  phone          String?
  isPrimary      Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leadCustomer LeadCustomer @relation(fields: [leadCustomerId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  activities   Activity[]

  @@index([leadCustomerId])
  @@index([branchId])
  @@index([email])
  @@index([phone])
}

model Activity {
  id             String         @id @default(cuid())
  leadCustomerId String
  branchId       String?
  contactId      String?
  ownerId        String
  createdById    String
  completedById  String?
  type           ActivityType
  status         ActivityStatus @default(OPEN)
  subject        String
  body           String?
  occurredAt     DateTime?
  dueAt          DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  leadCustomer LeadCustomer @relation(fields: [leadCustomerId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  owner        User         @relation("ActivityOwner", fields: [ownerId], references: [id])
  createdBy    User         @relation("ActivityCreatedBy", fields: [createdById], references: [id])
  completedBy  User?        @relation("ActivityCompletedBy", fields: [completedById], references: [id])

  @@index([leadCustomerId])
  @@index([ownerId])
  @@index([status])
  @@index([dueAt])
  @@index([type])
}

model LeadOwnershipHistory {
  id             String   @id @default(cuid())
  leadCustomerId String
  fromOwnerId    String?
  toOwnerId      String
  changedById    String
  reason         String
  createdAt      DateTime @default(now())

  leadCustomer LeadCustomer @relation(fields: [leadCustomerId], references: [id], onDelete: Cascade)
  fromOwner    User?        @relation("LeadOwnershipFrom", fields: [fromOwnerId], references: [id])
  toOwner      User         @relation("LeadOwnershipTo", fields: [toOwnerId], references: [id])
  changedBy    User         @relation("LeadOwnershipChangedBy", fields: [changedById], references: [id])

  @@index([leadCustomerId])
  @@index([toOwnerId])
  @@index([createdAt])
}

model PipelineStage {
  id        String            @id @default(cuid())
  name      String            @unique
  sortOrder Int
  kind      PipelineStageKind @default(OPEN)
  active    Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  opportunities Opportunity[]

  @@index([sortOrder])
  @@index([kind])
}

model Opportunity {
  id                String   @id @default(cuid())
  leadCustomerId    String
  branchId          String?
  stageId           String
  ownerId           String
  title             String
  productInterest   String?
  estimatedValueInr Decimal? @db.Decimal(14, 2)
  probability       Int?
  lastReachAt       DateTime?
  nextFollowUpAt    DateTime?
  notes             String?
  createdById       String
  updatedById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  leadCustomer LeadCustomer            @relation(fields: [leadCustomerId], references: [id], onDelete: Cascade)
  branch       Branch?                 @relation(fields: [branchId], references: [id], onDelete: SetNull)
  stage        PipelineStage           @relation(fields: [stageId], references: [id])
  owner        User                    @relation("OpportunityOwner", fields: [ownerId], references: [id])
  createdBy    User                    @relation("OpportunityCreatedBy", fields: [createdById], references: [id])
  updatedBy    User                    @relation("OpportunityUpdatedBy", fields: [updatedById], references: [id])
  splits       OpportunityOwnerSplit[]
  proposals    Proposal[]
  orders       Order[]

  @@index([leadCustomerId])
  @@index([branchId])
  @@index([stageId])
  @@index([ownerId])
  @@index([nextFollowUpAt])
  @@index([updatedAt])
}

model OpportunityOwnerSplit {
  opportunityId String
  userId        String
  percent       Int

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@id([opportunityId, userId])
  @@index([userId])
}

model SalesTarget {
  id             String   @id @default(cuid())
  ownerId        String
  financialYear  Int
  quarter        Int
  targetValueInr Decimal  @db.Decimal(14, 2)
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner     User @relation("SalesTargetOwner", fields: [ownerId], references: [id])
  createdBy User @relation("SalesTargetCreatedBy", fields: [createdById], references: [id])

  @@unique([ownerId, financialYear, quarter])
  @@index([financialYear, quarter])
}

model ProductService {
  id                           String   @id @default(cuid())
  name                         String
  code                         String?  @unique
  category                     String
  description                  String?
  defaultGstRateBps            Int      @default(1800)
  defaultProductionTemplateKey String?
  active                       Boolean  @default(true)
  sortOrder                    Int      @default(0)
  createdById                  String
  updatedById                  String
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  createdBy User @relation("ProductServiceCreatedBy", fields: [createdById], references: [id])
  updatedBy User @relation("ProductServiceUpdatedBy", fields: [updatedById], references: [id])
  proposalLineItems ProposalLineItem[]
  orderLineItems OrderLineItem[]

  @@index([active, sortOrder])
  @@index([category])
  @@index([name])
}

model Proposal {
  id                String         @id @default(cuid())
  opportunityId     String
  title             String
  sequenceNumber    Int
  versionLabel      String?
  status            ProposalStatus @default(DRAFT)
  currency          String         @default("INR")
  validUntil        DateTime?
  commercialSummary String?
  assumptions       String?
  inclusions        String?
  exclusions        String?
  paymentTerms      String?
  deliveryTimeline  String?
  internalNotes     String?
  subtotalPaisa     Int            @default(0)
  gstPaisa          Int            @default(0)
  totalPaisa        Int            @default(0)
  createdById       String
  updatedById       String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  opportunity Opportunity              @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdBy   User                     @relation("ProposalCreatedBy", fields: [createdById], references: [id])
  updatedBy   User                     @relation("ProposalUpdatedBy", fields: [updatedById], references: [id])
  lineItems   ProposalLineItem[]
  pdfAttachments ProposalPdfAttachment[]
  order       Order?

  @@unique([opportunityId, sequenceNumber])
  @@index([opportunityId])
  @@index([status])
  @@index([createdAt])
}

model ProposalLineItem {
  id                      String   @id @default(cuid())
  proposalId              String
  productServiceId        String
  productNameSnapshot     String
  productCategorySnapshot String
  description             String?
  quantity                Int
  unitPricePaisa          Int
  gstRateBps              Int
  gstOverrideReason       String?
  lineSubtotalPaisa       Int
  lineGstPaisa            Int
  lineTotalPaisa          Int
  sortOrder               Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  proposal       Proposal       @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  productService ProductService @relation(fields: [productServiceId], references: [id])
  orderLineItem  OrderLineItem?

  @@index([proposalId])
  @@index([productServiceId])
}

model ProposalPdfAttachment {
  id               String    @id @default(cuid())
  proposalId       String
  originalFileName String
  storedFileName   String
  storageProvider  String
  storageKey       String
  mimeType         String
  fileSizeBytes    Int
  sha256           String?
  canvaDesignUrl   String?
  uploadedById     String
  uploadedAt       DateTime  @default(now())
  replacedAt       DateTime?

  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("ProposalPdfUploadedBy", fields: [uploadedById], references: [id])

  @@index([proposalId])
  @@index([uploadedAt])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  proposalId      String      @unique
  opportunityId   String
  leadCustomerId  String
  branchId        String?
  ownerId         String
  status          OrderStatus @default(BOOKED)
  poNumber        String?
  poDate          DateTime?
  poFileName      String?
  poStorageKey    String?
  poFileSizeBytes Int?
  poMimeType      String?
  bookedAt        DateTime    @default(now())
  deliveryDueAt   DateTime?
  currency        String      @default("INR")
  subtotalPaisa   Int
  gstPaisa        Int
  totalPaisa      Int
  createdById     String
  updatedById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  proposal      Proposal       @relation(fields: [proposalId], references: [id])
  opportunity   Opportunity    @relation(fields: [opportunityId], references: [id])
  leadCustomer  LeadCustomer   @relation(fields: [leadCustomerId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  owner         User           @relation("OrderOwner", fields: [ownerId], references: [id])
  createdBy     User           @relation("OrderCreatedBy", fields: [createdById], references: [id])
  updatedBy     User           @relation("OrderUpdatedBy", fields: [updatedById], references: [id])
  lineItems     OrderLineItem[]
  splitSnapshots OrderOwnerSplitSnapshot[]

  @@index([status])
  @@index([ownerId])
  @@index([leadCustomerId])
  @@index([opportunityId])
  @@index([bookedAt])
  @@index([deliveryDueAt])
}

model OrderLineItem {
  id                            String   @id @default(cuid())
  orderId                       String
  proposalLineItemId            String   @unique
  productServiceId              String?
  productNameSnapshot           String
  productCategorySnapshot       String
  productionTemplateKeySnapshot String?
  description                   String?
  quantity                      Int
  unitPricePaisa                Int
  gstRateBps                    Int
  gstOverrideReason             String?
  lineSubtotalPaisa             Int
  lineGstPaisa                  Int
  lineTotalPaisa                Int
  sortOrder                     Int      @default(0)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  proposalLineItem ProposalLineItem @relation(fields: [proposalLineItemId], references: [id])
  productService   ProductService?  @relation(fields: [productServiceId], references: [id], onDelete: SetNull)
  productionWorkItems ProductionWorkItem[]

  @@index([orderId])
  @@index([productServiceId])
  @@index([productCategorySnapshot])
}

model OrderOwnerSplitSnapshot {
  orderId String
  userId  String
  percent Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@id([orderId, userId])
  @@index([userId])
}

model ProductionTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages    ProductionTemplateStage[]
  workItems ProductionWorkItem[]

  @@index([active, sortOrder])
}

model ProductionTemplateStage {
  id                  String   @id @default(cuid())
  templateId          String
  key                 String
  name                String
  description         String?
  required            Boolean  @default(true)
  defaultDurationDays Int?
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  template       ProductionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  stageInstances ProductionStageInstance[]

  @@unique([templateId, key])
  @@index([templateId, sortOrder])
}

model ProductionWorkItem {
  id                   String                @id @default(cuid())
  orderLineItemId      String
  productionTemplateId String?
  title                String
  productNameSnapshot  String
  productCategorySnapshot String
  status               ProductionStageStatus @default(NOT_STARTED)
  assignedToId         String?
  dueAt                DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  createdById          String
  updatedById          String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  orderLineItem      OrderLineItem       @relation(fields: [orderLineItemId], references: [id], onDelete: Cascade)
  productionTemplate ProductionTemplate? @relation(fields: [productionTemplateId], references: [id], onDelete: SetNull)
  assignedTo         User?               @relation("ProductionWorkItemAssignedTo", fields: [assignedToId], references: [id])
  createdBy          User                @relation("ProductionWorkItemCreatedBy", fields: [createdById], references: [id])
  updatedBy          User                @relation("ProductionWorkItemUpdatedBy", fields: [updatedById], references: [id])
  stageInstances     ProductionStageInstance[]
  notes              ProductionNote[]

  @@index([orderLineItemId])
  @@index([productionTemplateId])
  @@index([status])
  @@index([assignedToId])
  @@index([dueAt])
  @@index([productCategorySnapshot])
}

model ProductionStageInstance {
  id              String                @id @default(cuid())
  workItemId      String
  templateStageId String?
  name            String
  description     String?
  status          ProductionStageStatus @default(NOT_STARTED)
  required        Boolean               @default(true)
  sortOrder       Int                   @default(0)
  assignedToId    String?
  dueAt           DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  completedById   String?
  skippedReason   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  workItem      ProductionWorkItem      @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  templateStage ProductionTemplateStage? @relation(fields: [templateStageId], references: [id], onDelete: SetNull)
  assignedTo    User?                   @relation("ProductionStageAssignedTo", fields: [assignedToId], references: [id])
  completedBy   User?                   @relation("ProductionStageCompletedBy", fields: [completedById], references: [id])
  notes         ProductionNote[]

  @@index([workItemId])
  @@index([templateStageId])
  @@index([status])
  @@index([assignedToId])
  @@index([dueAt])
}

model ProductionNote {
  id              String   @id @default(cuid())
  workItemId      String
  stageInstanceId String?
  body            String
  createdById     String
  createdAt       DateTime @default(now())

  workItem      ProductionWorkItem     @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  stageInstance ProductionStageInstance? @relation(fields: [stageInstanceId], references: [id], onDelete: SetNull)
  createdBy     User                   @relation("ProductionNoteCreatedBy", fields: [createdById], references: [id])

  @@index([workItemId])
  @@index([stageInstanceId])
  @@index([createdById])
  @@index([createdAt])
}
